# CATALYST Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Required ─────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# PostgreSQL connection string (Supabase URL format)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ─── Optional ──────────────────────────────────────
# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://your-catalyst.vercel.app

# NewsAPI key for security agent (free tier at https://newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# ─── Local Development ─────────────────────────────
# Uses SQLite by default when no DATABASE_URL is set
# DATABASE_URL=sqlite:///./catalyst.db
